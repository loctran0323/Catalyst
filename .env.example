# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Legacy JWT anon key, or new publishable key (sb_publishable_…)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key
# Optional alias if you prefer the new name:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Production: your Vercel URL (no trailing slash). Also used for redirects; email confirm uses the
# browser origin at signup time if you sign up on Vercel, but keep this correct for production builds.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (https://resend.com) — test digests from Settings
RESEND_API_KEY=
# Default onboarding@resend.dev only delivers to your Resend account email. For any recipient,
# verify a domain at https://resend.com/domains and use an address on that domain, e.g.:
# RESEND_FROM_EMAIL=Catalyst <digest@yourdomain.com>
RESEND_FROM_EMAIL=onboarding@resend.dev

# Optional: AI summaries for news headlines on the dashboard / explore.
OPENAI_API_KEY=

# Optional: Tavily (https://tavily.com) — archive “Read coverage” prefers the top article URL from
# search; without it we use Google News RSS / a Google News search link.
TAVILY_API_KEY=

# Vercel Cron: set in Vercel project env; optional for local
CRON_SECRET=generate_a_long_random_string

# Future: batch digests listing all users (service role — server only, never expose)
# SUPABASE_SERVICE_ROLE_KEY=
